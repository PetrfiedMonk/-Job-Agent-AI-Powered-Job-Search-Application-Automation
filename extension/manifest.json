{
  "manifest_version": 3,
  "name": "Job Agent",
  "version": "1.0.0",
  "description": "AI job hunting sidekick. See your agent status, detect job postings, and queue applications with one click.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "http://localhost:8000/*",
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.ziprecruiter.com/*",
    "*://*.glassdoor.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Job Agent"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/rc/clk*",
        "*://*.indeed.com/pagead/*",
        "*://*.ziprecruiter.com/jobs/*",
        "*://*.glassdoor.com/Job/*",
        "*://*.glassdoor.com/job-listing/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
